# Скопируй в .env.local и подставь значения из Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Секрет для keepalive-эндпоинта (любая случайная строка). Vercel Cron шлёт его в заголовке.
CRON_SECRET=change-me-to-a-random-string
